{
    $schema: "./vendor/infection/infection/resources/schema.json",
    source: {
        directories: [
            "src"
        ],
        excludes: [
            "Contracts",
            "Exceptions",
            "Enums",
            "Events",
            "Facades",
            "MfaServiceProvider.php"
        ]
    },
    logs: {
        summary: "build/infection-summary.log",
        text: "build/infection.log"
    },
    phpUnit: {
        configDir: ".",
        customPath: "vendor/bin/phpunit"
    },
    timeout: 15,
    mutators: {
        "@default": true,
        // String concatenation mutations on error messages do not exercise
        // any observable behaviour — the message text is not asserted and
        // a mangled string is still unambiguous to the developer reading
        // logs. Exclude to keep the MSI signal focused on logic.
        "Concat": false,
        "ConcatOperandRemoval": false,
        // Visibility mutations (protected → public) change the reachable
        // API surface but do not change runtime behaviour, so they cannot
        // be caught by test assertions without reflection plumbing that
        // adds no real safety.
        "ProtectedVisibility": false
    }
}
